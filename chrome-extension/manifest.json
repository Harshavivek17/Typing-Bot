{
  "manifest_version": 3,
  "name": "TypeBot – Auto Typer for Typing Tests",
  "version": "1.1.0",
  "description": "An auto-typing bot for MonkeyType and other typing test platforms. Set your target WPM and let it type for you.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "debugger"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}